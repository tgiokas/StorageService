# ============================================
# Storage Provider: MinIO | SeaweedFS | AzureBlob | Garage
# ============================================
STORAGE_PROVIDER=Garage

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# SeaweedFS (unused when STORAGE_PROVIDER=MinIO)
SEAWEEDFS_MASTER_URL=http://seaweedfs-master:9333
SEAWEEDFS_FILER_URL=http://seaweedfs-filer:8888

# Azure Blob (unused when STORAGE_PROVIDER=MinIO)
AZURE_BLOB_CONNECTION_STRING=

# Garage (unused when STORAGE_PROVIDER=MinIO)
# https://garagehq.deuxfleurs.fr — S3-compatible distributed object store
GARAGE_ENDPOINT=garage:3900
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
GARAGE_USE_SSL=false
GARAGE_REGION=garage

# ============================================
# Encryption (AES-256-GCM)
# ============================================
ENCRYPTION_ENABLED=true
ENCRYPTION_MASTER_KEY=K7gNU3sdo+OL0wNhqoVWhr3g6s1xYv72ol/pe/Unols=

# ============================================
# Indexing (Elasticsearch)
# ============================================
INDEXING_ENABLED=true
INDEXING_ELASTIC_URL=http://elasticsearch:9200
INDEXING_ELASTIC_INDEX=document-indexes

# ============================================
# Database (EF Core � ApplicationDbContext)
# ============================================
STORAGE_DB_POSTGRES_USER=storageuser
STORAGE_DB_POSTGRES_PASSWORD=storagepass
STORAGE_DB_POSTGRES_DB=storagedb
STORAGE_DB_CONNECTION=Host=storage-db;Port=5432;Database=storagedb;Username=storageuser;Password=storagepass
